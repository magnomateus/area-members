# ─────────────────────────────────────────────────────────────
# .env.example — Plataforma de Membros VIS
# Copie para `.env` e preencha. Variaveis conforme ARCHITECTURE.md secao 13.
# ─────────────────────────────────────────────────────────────

# Banco de dados — Supabase Postgres.
# DATABASE_URL: pooler (porta 6543) — usado pelo Prisma Client em runtime.
# DIRECT_URL:   conexao direta (porta 5432) — usado pelo Prisma Migrate.
# Ambos obrigatorios. Sem DIRECT_URL, as migrations falham contra o Supabase.
# Se a senha tiver caracteres especiais (@ : / etc), faca percent-encoding.
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Auth — segredo de sessao (gerar 64 chars aleatorios)
SESSION_SECRET=

# VIS Platform — secret do webhook.
# NAO armazenar o secret do webhook por aqui: cada tenant tem o seu, em
# Tenant.visWebhookSecret no banco. Esta variavel e APENAS um fallback de dev.
VIS_WEBHOOK_SECRET_DEV=

# WhatsApp (Evolution API ou Z-API)
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=

# Storage (Supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Push (Web Push / VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:suporte@missaexplicada.com.br

# Observabilidade
SENTRY_DSN=

# Feature flags
ENABLE_WEBHOOK_SIMULATOR=false
