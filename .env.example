# ─────────────────────────────────────────────────────────────
# .env.example — Plataforma de Membros VIS
# Copie para `.env` e preencha. Variaveis conforme ARCHITECTURE.md secao 13.
# ─────────────────────────────────────────────────────────────

# Banco de dados (PostgreSQL)
# Dev local via Docker (docker-compose.yml) usa a porta 5433 do host.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/vis_membros_dev"

# Auth — segredo de sessao (gerar 64 chars aleatorios)
SESSION_SECRET=

# VIS Platform — secret do webhook.
# Multi-tenant: o secret efetivo e resolvido por Tenant.visWebhookSecret no banco.
# Esta variavel serve como fallback/global.
VIS_WEBHOOK_SECRET=

# WhatsApp (Evolution API ou Z-API)
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=

# Storage (Supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Push (Web Push / VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:suporte@missaexplicada.com.br

# Observabilidade
SENTRY_DSN=

# Feature flags
ENABLE_WEBHOOK_SIMULATOR=false
